PORT=8080
# Matches docker-compose.yml credentials
DATABASE_URL=postgres://aaryauser:aaryapass@localhost:5432/aaryashop?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string
OTP_EXPIRY_MINUTES=5
RATE_LIMIT_PER_MINUTE=60

# Admin seeding — these identifiers are upserted as admin on every startup
ADMIN_PHONE=919999999999
ADMIN_EMAIL=admin@aaryashop.com

# SMS — Fast2SMS (India)
# Get key at https://www.fast2sms.com → API → Dev API
FAST2SMS_API_KEY=your_fast2sms_api_key

# Email — Resend
# Get key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=orders@aaryashop.com
FROM_NAME=AaryaShop

# Vendor contact for new-order notifications
VENDOR_EMAIL=vendor@aaryashop.com
VENDOR_PHONE=919999999999

# Razorpay (optional — leave blank to use COD only)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
